PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Copy config/sources.example.json to config/sources.json and edit it.
SOURCES_CONFIG_PATH=config/sources.json

# Optional for production persistence. The scaffold currently runs in memory.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sms_news

# Optional. If unset, summaries are generated by a deterministic local stub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional. If unset, SMS delivery logs to stdout.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PERSONAL_PHONE_NUMBER=

# Set this before exposing /jobs/daily-digest publicly.
JOB_SECRET=change-me

# Used for signed feedback links.
FEEDBACK_SECRET=change-me-too
