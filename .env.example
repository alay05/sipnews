PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Copy config/sources.example.json to config/sources.json and edit it.
SOURCES_CONFIG_PATH=config/sources.json

# Optional for production persistence. Leave blank to run in memory.
DATABASE_URL=

# Optional. If unset, summaries are generated by a deterministic local stub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SOURCE_FETCH_TIMEOUT_MS=15000
DISABLE_GDELT=false

# Optional. Enables Guardian Open Platform sources in config/sources.example.json.
THE_GUARDIAN_API_KEY=

# Optional. If unset, SMS delivery logs to stdout.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SEND_SMS=true
TWILIO_VALIDATE_WEBHOOKS=false

# Optional. Enables SendGrid email delivery for the daily digest.
SENDGRID_API_KEY=
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_TO=
SEND_EMAIL=false

PERSONAL_PHONE_NUMBER=
PERSONAL_USER_ID=personal
PERSONAL_DISPLAY_NAME=
PERSONAL_TIMEZONE=America/New_York
DIGEST_SEND_HOUR=7
DIGEST_MAX_ITEMS=10

# Set this before exposing /jobs/daily-digest publicly.
JOB_SECRET=change-me

# Used for signed feedback links.
FEEDBACK_SECRET=change-me-too
