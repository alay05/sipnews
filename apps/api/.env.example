# API server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Local development must use a dev-only database, never the Render production DB.
DATABASE_URL=
DATABASE_ENV=development

# Clerk JWT verification for authenticated /v1/me routes.
CLERK_JWT_ISSUER=
CLERK_SECRET_KEY=
CLERK_JWT_AUDIENCE=

# Optional comma-separated allowlist while only a small number of users exist.
ALLOWED_USER_EMAILS=
