# API server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Source config is owned by the API. Copy config/sources.example.json to
# config/sources.json for local edits.
SOURCES_CONFIG_PATH=../../config/sources.json
SOURCE_FETCH_TIMEOUT_MS=15000
MAX_ARTICLE_AGE_DAYS=7
DISABLE_GDELT=false
THE_GUARDIAN_API_KEY=

# Persistence. Leave blank to use the in-memory store locally.
DATABASE_URL=

# Summaries. If OPENAI_API_KEY is blank, the API uses its local deterministic
# summarizer stub.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Scheduled job protection.
JOB_SECRET=change-me

# Signed feedback links.
FEEDBACK_SECRET=change-me-too

# Email-only digest delivery.
SEND_EMAIL=true
SENDGRID_API_KEY=
DIGEST_EMAIL_FROM=
DIGEST_EMAIL_TO=

# Legacy SMS code remains present, but email is the supported delivery path.
SEND_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_WEBHOOKS=false

# Current user seeding. PERSONAL_PHONE_NUMBER is still required by
# runDailyDigest.ts even when SEND_SMS=false; treat it as legacy identity input
# until Clerk-backed users replace this path.
PERSONAL_PHONE_NUMBER=
PERSONAL_USER_ID=personal
PERSONAL_DISPLAY_NAME=
PERSONAL_TIMEZONE=America/New_York
DIGEST_SEND_HOUR=7
DIGEST_MAX_ITEMS=10

# Reserved for the API auth task. Clerk browser keys belong in apps/web.
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
