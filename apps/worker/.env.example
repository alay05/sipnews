# Worker runtime
NODE_ENV=development

# Required shared service connections.
DATABASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SUMMARY_PROMPT_VERSION=worker-v1

# Source fetching and digest freshness. When running through npm workspaces,
# this path is relative to apps/worker.
SOURCES_CONFIG_PATH=../../config/sources.json
SOURCE_FETCH_TIMEOUT_MS=15000
MAX_ARTICLE_AGE_DAYS=7

# Email delivery.
PUBLIC_BASE_URL=http://localhost:3000
SENDGRID_API_KEY=
DIGEST_EMAIL_FROM=

# Source config files remain shared under config/.
