# Worker scaffold
NODE_ENV=development

# Shared service connections expected once background processing moves out of
# apps/api. Keep names aligned with apps/api unless worker code explicitly
# introduces a different contract.
DATABASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Worker-to-API coordination, if a task needs to call API endpoints instead of
# importing shared packages.
API_BASE_URL=http://localhost:3000
JOB_SECRET=change-me

# Source config remains owned by apps/api for now. Do not add a worker-specific
# source path unless the worker becomes the source-fetch owner.
SOURCES_CONFIG_PATH=
