# Worker runtime
NODE_ENV=development

# Required shared service connections. Keep local worker runs on the same
# dev-only database as the local API, never the Render production DB.
# Local development usually keeps both prepare and deliver values in one file,
# but production splits them by service.
DATABASE_URL=
DATABASE_ENV=development
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
SUMMARY_PROMPT_VERSION=worker-v1

# Source fetching and digest freshness. When running through npm workspaces,
# this path is relative to apps/worker and is used by prepare flows. The
# committed default is ../../config/sources.json. Point this at
# ../../config/sources.local.json only if you want a local-only override.
SOURCES_CONFIG_PATH=../../config/sources.json
SOURCE_FETCH_TIMEOUT_MS=15000
MAX_ARTICLE_AGE_DAYS=7

# Delivery-only values. Local worker:deliver runs use these too and can send
# real email through SendGrid.
PUBLIC_BASE_URL=http://localhost:3000
SENDGRID_API_KEY=
DIGEST_EMAIL_FROM=

# Prepare-only provider keys when the committed source config enables them.
THE_GUARDIAN_API_KEY=

# Source config files remain shared under config/.
